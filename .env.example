# Environment variables for local development.
# Copy this file to .env and replace placeholders with real local values.
# Never commit real secrets.

APP_ENV=development
LOG_LEVEL=debug
APP_NAME="Top Comment Studio"

# Runway API
RUNWAYML_API_SECRET=your_runway_api_secret_here
RUNWAYML_API_BASE_URL=https://api.dev.runwayml.com
RUNWAYML_API_VERSION=2024-11-06
RUNWAY_WORKFLOW_REGISTRY_URL=https://dev.runwayml.com/organization/8f8366b8-b7b6-4f9c-baae-f72c16c9f79f/workflows

# AI providers
OPENAI_API_KEY=your_openai_api_key_here

# Database / storage
DATABASE_URL=your_database_url_here

# Web app
PORT=3000
HOST=localhost

# Optional integrations
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local app data
TOP_COMMENT_STUDIO_DATA_DIR=data/local
